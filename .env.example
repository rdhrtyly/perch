# ─────────────────────────────────────────────────────────────────
#  Perch settings
#  Copy this file to ".env" and fill in real values.
#  NEVER commit your real .env to GitHub. (.gitignore already hides it.)
# ─────────────────────────────────────────────────────────────────

# Port the control server listens on. Caddy sends your dashboard here.
PORT=3000

# The secret password for the webhook. You paste this SAME value into
# GitHub later so only YOU can trigger deploys.
# Make a strong random one on the server with:  openssl rand -hex 32
WEBHOOK_SECRET=changeme-make-this-long-and-random

# Your root domain. Each site becomes  <name>.BASE_DOMAIN
#   BASE_DOMAIN=useperch.dev   ->   forkful.useperch.dev
BASE_DOMAIN=useperch.dev

# Where the Perch dashboard itself lives.
# Using the apex (useperch.dev) means your dashboard IS useperch.dev.
# Prefer a subdomain? Use something like  app.useperch.dev  instead.
DASHBOARD_DOMAIN=useperch.dev

# Email address Let's Encrypt uses when making your free HTTPS padlocks.
ACME_EMAIL=you@example.com

# A GitHub token — only needed if you deploy PRIVATE repos.
# Leave blank for public repos. (Make one at github.com/settings/tokens,
# "Fine-grained", read-only "Contents" access.)
GITHUB_TOKEN=

# Folder Perch uses to store everything on disk.
DATA_DIR=./data

# This server's public IP. Phase 2 uses it to auto-point bought domains here.
SERVER_IP=206.189.181.166

# ─────────────────────────────────────────────────────────────────
#  PHASE 2 — Porkbun (buying domains from the dashboard).
#  Make these in Porkbun: Account → API Access. Turn ON "API Access"
#  for each domain you want to manage. Keys look like pk1_... / sk1_...
#  When both are filled in, the "Domains" tab turns on automatically.
# ─────────────────────────────────────────────────────────────────
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=
